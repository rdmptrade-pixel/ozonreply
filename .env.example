# Timeweb App Platform — переменные окружения
# Скопируйте этот файл в .env для локальной разработки
# На Timeweb все эти переменные задаются в панели управления

# База данных PostgreSQL (обязательно на Timeweb)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Отключить SSL для внутреннего PostgreSQL на Timeweb (обязательно!)
DATABASE_SSL=false

# Ozon API
OZON_CLIENT_ID=135416
OZON_API_KEY=your-ozon-api-key

# AI провайдер
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
PERPLEXITY_API_KEY=
OPENAI_API_KEY=

# JWT (придумайте любую длинную строку)
JWT_SECRET=your-very-long-random-secret-string

# Порт (Timeweb задаёт автоматически, не трогайте)
# PORT=3000
